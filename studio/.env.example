# ── Backend connection ──────────────────────────────────────────
# The studio uses a server-side proxy at src/app/api/[...path]/route.ts
# that forwards every /api/* call to BACKEND_URL and injects the
# X-Studio-Key header from STUDIO_API_KEY. Both vars are server-only;
# the browser never sees the key.
BACKEND_URL=http://localhost:8000

# Must match the backend's STUDIO_API_KEY. Empty = no header sent
# (use this when the backend is running without auth).
STUDIO_API_KEY=

# ── Studio login gate (optional) ────────────────────────────────
# When set, the studio shows a cookie-based login page before any
# editor screen. Empty = no gate (dev default).
STUDIO_PASSWORD=
