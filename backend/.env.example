# ── LLM Provider ────────────────────────────────────────────────
# openai | b-api-openai | b-api-academiccloud   (default: openai)
LLM_PROVIDER=openai

# Native OpenAI key.
# REQUIRED when LLM_PROVIDER=openai (chat + embeddings + moderation + speech).
# OPTIONAL when LLM_PROVIDER=b-api-* — but if provided, the backend uses it
# as a side channel for the OpenAI-only features that B-API does not
# forward: /v1/moderations (free safety classifier), /v1/audio/transcriptions
# (Whisper-STT) and /v1/audio/speech (TTS). Without an OpenAI key these
# features are silently disabled on b-api-* setups.
OPENAI_API_KEY=sk-...

# Optional: override the OpenAI base URL to use an OpenAI-compatible endpoint
# (Azure OpenAI, LiteLLM-Proxy, LocalAI, Ollama, …). Empty / unset = SDK
# default (https://api.openai.com/v1). Note: the backend treats empty
# string and unset identically — both fall back to the SDK default.
# Example:
#   OPENAI_BASE_URL=https://my-openai-proxy.example.com/v1
OPENAI_BASE_URL=

# B-API (required when LLM_PROVIDER=b-api-*; ignored otherwise)
# Default: PROD instance. For integration testing use the staging URL:
#   B_API_BASE_URL=https://b-api.staging.openeduhub.net/api/v1/llm
B_API_KEY=
B_API_BASE_URL=https://b-api.prod.openeduhub.net/api/v1/llm

# Model overrides — leave empty to use the provider defaults:
#   openai                     → chat: gpt-5.4-mini, embed: text-embedding-3-small
#   b-api-openai               → chat: gpt-4.1-mini, embed: text-embedding-3-small
#                                (B-API proxy forwards GPT-5 model names but NOT the
#                                 new reasoning_effort / verbosity parameters yet,
#                                 so we stick to gpt-4.1-mini as its default.)
#   b-api-academiccloud        → chat: Qwen/Qwen3.5-122B-A10B-GPTQ-Int4,
#                                embed: e5-mistral-7b-instruct
LLM_CHAT_MODEL=
LLM_EMBED_MODEL=

# Legacy var, still respected when LLM_PROVIDER=openai and LLM_CHAT_MODEL is empty
OPENAI_MODEL=

# ── GPT-5-series parameters (native OpenAI + gpt-5*/o3*/o4* models only) ─
# Silently ignored for gpt-4.x and for all b-api-* providers.
#   LLM_VERBOSITY        low | medium | high                  (default: medium)
#                        Drives answer length. Sent on every GPT-5 call
#                        (with or without tools). "medium" matches the
#                        GPT-5.4 model default and produces answers of
#                        roughly gpt-4.1-mini length; pick "low" for
#                        terse replies, "high" for long-form output.
#   LLM_REASONING_EFFORT none | low | medium | high | xhigh   (default: low)
#                        Only sent on tool-LESS turns — OpenAI rejects
#                        reasoning_effort + tools on /v1/chat/completions.
#                        With tools the server falls back to "none" and
#                        temperature/top_p are allowed to ride along.
# Note: no max_completion_tokens / max_output_tokens is sent. On reasoning
# models that field is the TOTAL budget (reasoning + output), which would
# silently starve short call-sites. Output length is steered via verbosity.
LLM_VERBOSITY=medium
LLM_REASONING_EFFORT=low

# ── Speech (STT/TTS) ────────────────────────────────────────────
# Speech features always talk directly to an OpenAI-compatible endpoint
# (OPENAI_API_KEY + optional OPENAI_BASE_URL). The B-API proxies do
# NOT forward audio endpoints, so setting LLM_PROVIDER=b-api-* still
# routes speech to native OpenAI.
# STT_MODEL   — default: gpt-4o-mini-transcribe  (fallbacks to gpt-4o-transcribe, whisper-1)
# TTS_MODEL   — default: tts-1                   (set tts-1-hd for higher quality)
STT_MODEL=
TTS_MODEL=

# ── MCP / RAG ───────────────────────────────────────────────────
MCP_SERVER_URL=https://wlo-mcp-server.vercel.app/mcp

# ── Text-Extraction (Phase 2 — Remix von URL-Inhalten) ──────────
# OEH-Volltext-Service zum Extrahieren des Textinhalts beliebiger
# Web-Seiten. Wird vom Canvas-Remix-Flow genutzt, um z.B. eine
# Wikipedia-Seite oder einen Blogpost als Quellmaterial einzulesen.
#
# Erwartet die **Base-URL** des Dienstes — der konkrete /from-url-
# Endpoint wird intern angehängt. Die Resolver-Logik toleriert:
#   - Trailing-Slash    (.../net/  ↔  .../net)
#   - Volle Legacy-URL  (.../net/from-url  →  Suffix wird gestrippt)
#   - Leere Werte       (Docker-Compose ${VAR:-} → Fallback auf Default)
#
# Default: PROD. Für Integration-Tests stattdessen:
#   TEXT_EXTRACTION_URL=https://text-extraction.staging.openeduhub.net
TEXT_EXTRACTION_URL=https://text-extraction.prod.openeduhub.net

# ── Persistence ─────────────────────────────────────────────────
DATABASE_PATH=badboerdi.db

# ── Evaluation (automatisierte Persona-Dialog-Tests) ────────────
# Das Eval-System fuehrt simulierte Nutzer-Dialoge gegen das echte
# /api/chat-Endpoint. Alle Werte haben sinnvolle Defaults; nur in
# exotischen Deployments (Eval laeuft auf anderem Host als Backend)
# muessen sie gesetzt werden.
#
# EVAL_CHAT_URL       Default: http://localhost:8000/api/chat
#                     Ziel fuer die simulierten Chat-Calls. Bei Self-
#                     Loopback im Container bleibt localhost korrekt.
# EVAL_SIMULATOR_MODEL Default: gpt-4o-mini
#                     Modell fuer den User-Simulator + Szenario-Generator.
# EVAL_JUDGE_MODEL    Default: gpt-4o-mini
#                     Modell fuer den LLM-as-Judge-Scorer.
EVAL_CHAT_URL=
EVAL_SIMULATOR_MODEL=
EVAL_JUDGE_MODEL=

# ── Studio API protection ───────────────────────────────────────
# Empty = open (dev default). When set, /api/config, /api/rag, /api/safety
# and the protected /api/sessions/* routes require header
#   X-Studio-Key: <value>
# (or query param ?key=<value>). Must match the studio's STUDIO_API_KEY.
STUDIO_API_KEY=
